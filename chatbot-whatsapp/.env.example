# --- WhatsApp Cloud API (Meta) ---
# developers.facebook.com -> tu App -> WhatsApp -> API Setup
WHATSAPP_TOKEN=EAAG...                       # Access Token (System User para producción)
WHATSAPP_PHONE_NUMBER_ID=123456789012345      # Phone number ID del remitente
WHATSAPP_VERIFY_TOKEN=mi_token_secreto_xyz    # Lo eliges tú; debe coincidir con el del webhook
GRAPH_API_VERSION=v21.0

# --- Google Calendar (Service Account) ---
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
GOOGLE_CALENDAR_ID=tucalendario@group.calendar.google.com

# --- Negocio ---
TIMEZONE=America/Mexico_City
BUSINESS_HOURS_START=9
BUSINESS_HOURS_END=18
SLOT_MINUTES=30

# --- Servidor ---
PORT=3000
