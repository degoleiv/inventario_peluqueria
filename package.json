{
  "name": "inventario-peluqueria",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n server,vite -c blue,green \"npm run dev:server\" \"wait-on -t 90000 tcp:127.0.0.1:3010 && npm run dev:vite\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:vite": "vite",
    "dev:tauri": "tauri dev",
    "build": "vite build",
    "build:server": "tsc -p server/tsconfig.json",
    "reset:bootstrap": "tsx scripts/reset-usuarios-bootstrap.ts",
    "reset:total": "tsx scripts/reset-total-db.ts",
    "reset:ventas": "tsx scripts/reset-ventas.ts",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "@emoji-mart/data": "^1.2.1",
    "@emoji-mart/react": "^1.1.1",
    "@phosphor-icons/react": "^2.1.10",
    "@tauri-apps/api": "^2.2.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "emoji-mart": "^5.6.0",
    "express": "^4.21.2",
    "express-async-errors": "^3.1.1",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.7",
    "puppeteer": "^24.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.14.2",
    "sqlite3": "^6.0.1",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.2.7",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "tsx": "^4.19.2",
    "typescript": "~5.6.2",
    "vite": "^6.0.0",
    "wait-on": "^9.0.5"
  }
