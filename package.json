{
  "name": "inventario-peluqueria",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n server,vite -c blue,green \"npm run dev:server\" \"wait-on -t 90000 tcp:127.0.0.1:3010 && npm run dev:vite\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:vite": "vite",
    "dev:tauri": "tauri dev",
    "build": "vite build",
    "build:server": "tsc -p server/tsconfig.json",
    "reset:bootstrap": "tsx scripts/reset-usuarios-bootstrap.ts",
    "reset:total": "tsx scripts/reset-total-db.ts",
    "reset:ventas": "tsx scripts/reset-ventas.ts",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:pos": "playwright test --config=playwright.pos.config.ts",
    "test:stress": "node tests/stress/run-stress.mjs",
    "test:all": "npm run test:coverage && npm run test:e2e:pos"
  },
  "dependencies": {
    "@emoji-mart/data": "^1.2.1",
    "@emoji-mart/react": "^1.1.1",
    "@phosphor-icons/react": "^2.1.10",
    "@tauri-apps/api": "^2.2.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "emoji-mart": "^5.6.0",
    "express": "^4.21.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.5.1",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.7",
    "pdf-lib": "^1.17.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.14.2",
    "sqlite3": "^6.0.1",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tauri-apps/cli": "^2.2.7",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/supertest": "^6.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.9",
    "autocannon": "^7.15.0",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "jsdom": "^25.0.1",
    "supertest": "^7.2.2",
    "tsx": "^4.19.2",
    "typescript": "~5.6.2",
    "vite": "^6.0.0",
    "vitest": "^2.1.9",
    "wait-on": "^9.0.5"
  }
}
