{
  "name": "inventario-peluqueria-api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "API REST (Express + SQLite). Copiá esta carpeta a producción, ejecutá npm ci --omit=dev, npm run build y npm start.",
  "scripts": {
    "dev": "tsx watch index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "express-async-errors": "^3.1.1",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.7",
    "pdf-lib": "^1.17.1",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.0",
    "@types/nodemailer": "^8.0.0",
    "tsx": "^4.19.2",
    "typescript": "~5.6.2"
  }
}
