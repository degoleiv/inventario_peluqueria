{
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "../dist/server",
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true,
    "types": ["node"]
  },
  "include": ["./**/*.ts", "./**/*.d.ts"],
  "exclude": ["./future"]
}
